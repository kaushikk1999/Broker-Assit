# BrokerAssist backend env (prefix BA_ for app settings). Mocks-first defaults work with zero config.
BA_ENVIRONMENT=local
BA_USE_MOCKS=true

# Market-data provider (roadmap Source 2A). "mock" keeps the deterministic mock until a real
# TrueData/Ticker adapter is wired — safe even when BA_USE_MOCKS=false.
BA_MARKETDATA_PROVIDER=mock

# --- Storage ---
BA_DATABASE_URL=sqlite:///./brokerassist.db
# BA_DATABASE_URL=postgresql+psycopg2://brokerassist:brokerassist@localhost:5432/brokerassist
BA_REDIS_URL=
# BA_REDIS_URL=redis://localhost:6379/0

# --- Security ---
BA_SESSION_JWT_SECRET=dev-only-change-me
BA_SESSION_TTL_SECONDS=1800
BA_ADMIN_JWT_SECRET=dev-only-change-me-admin
BA_ADMIN_JWT_TTL_SECONDS=3600

# --- Abuse / quotas ---
BA_RATE_LIMIT_PER_SESSION_PER_MIN=20
BA_RATE_LIMIT_PER_IP_PER_MIN=40
BA_TENANT_DAILY_QUOTA=5000

# --- Qdrant (vector store; dual-vector brokerage_kb collection) ---
# These are SECRETS. Never commit a filled .env. Rotate keys that were shared in plaintext.
BA_QDRANT_URL=
BA_QDRANT_API_KEY=
# Canonical collection name (roadmap). Legacy alias BA_QDRANT_COLLECTION still accepted.
BA_QDRANT_COLLECTION_NAME=brokerage_kb
BA_QDRANT_DENSE_VECTOR_NAME=dense
BA_QDRANT_SPARSE_VECTOR_NAME=sparse
BA_QDRANT_VALIDATE_ON_STARTUP=true
# Collection creation is a startup responsibility; OFF by default (validate-only). Legacy alias:
# BA_QDRANT_CREATE_IF_MISSING. Set true (after confirming policy) to auto-create brokerage_kb.
BA_QDRANT_CREATE_COLLECTION_ON_STARTUP=false

# --- Phase 5: Embedding pipeline (Ollama Cloud · embeddinggemma) ---
# SECRETS — inject via env/Railway, never commit. Real path active only when BA_USE_MOCKS=false.
BA_OLLAMA_CLOUD_URL=
BA_OLLAMA_CLOUD_API_KEY=
BA_EMBEDDING_MODEL=embeddinggemma
# Dimension is detected dynamically from a probe; this is an OPTIONAL validation override only.
# BA_EMBEDDING_DIMENSION_OVERRIDE=
BA_EMBEDDING_BATCH_SIZE=16
BA_EMBEDDING_CONCURRENCY=2
BA_EMBEDDING_RETRY_COUNT=3
BA_EMBEDDING_TIMEOUT_SECONDS=30
# Conditional fail-fast: stop startup only when a REAL configured vendor violates the contract.
BA_INGESTION_FAIL_FAST=true
BA_METADATA_LANGUAGE_CODES=en,hi,ta
BA_METADATA_FILING_TYPES=Annual Report,Quarterly Results,Shareholding Pattern,Board Meeting,Corporate Action,Financial Results,Press Release,Presentation,FAQ
